# =============================================================
# Cloudinary Credentials
# Copy file này thành .env và điền giá trị thật vào
# Lấy thông số tại: https://console.cloudinary.com/
# Settings -> API Keys
# =============================================================

CLOUDINARY__CLOUDNAME=your-cloud-name
CLOUDINARY__APIKEY=your-api-key
CLOUDINARY__APISECRET=your-api-secret
CLOUDINARY__FOLDER=products

# =============================================================
# Database Connection
# =============================================================
ConnectionStrings__MyConnectString=your-connection-string

# =============================================================
# JWT Settings
# =============================================================
JwtSettings__SecretKey=your-jwt-secret-key

# =============================================================
# Email Settings
# =============================================================
EmailSettings__SenderEmail=your-email@gmail.com
EmailSettings__AppPassword=your-app-password
