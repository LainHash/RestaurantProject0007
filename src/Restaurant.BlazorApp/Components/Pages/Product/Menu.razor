@page "/Menu"
@using Restaurant.BlazorApp.Components.Shared
@using Restaurant.BlazorApp.Services.Abstraction.Catalog
@using Restaurant.Contracts.DTOs.Catalog.Categories
@using Restaurant.Contracts.DTOs.Catalog.Products
@inject ICategoryService CategoryService
@inject IProductService ProductService
@rendermode InteractiveServer

<PageHeader Page="Menu" />

<!-- Menu Start -->
<div class="menu">
    <div class="container">
        <div class="section-header text-center">
            <p>Thực đơn</p>
        </div>
        <div class="menu-tab">
            <ul class="nav nav-pills justify-content-center">
                @if (_categories != null)
                {
                    var isFirst = true;
                    @foreach (var category in _categories)
                    {
                        var tabId = $"tab-{category.Id}";
                        <li class="nav-item">
                            <a class="nav-link @(isFirst ? "active" : "")" data-toggle="pill" href="#@tabId">@category.Name</a>
                        </li>
                        isFirst = false;
                    }
                }
            </ul>
            <div class="tab-content">
                @if (_categories != null && _products != null)
                {
                    var isFirst = true;
                    @foreach (var category in _categories)
                    {
                        var tabId = $"tab-{category.Id}";
                        var categoryProducts = _products.Where(p => p.CategoryName == category.Name).ToList();

                        <div id="@tabId" class="container tab-pane @(isFirst ? "active" : "fade")">
                            <div class="row">
                                <div class="col-lg-7 col-md-12">
                                    @foreach (var product in categoryProducts)
                                    {
                                        <div class="menu-item">
                                            <div class="menu-img">
                                                <img src="@GetProductImageUrl(product)" alt="@product.Name">
                                            </div>
                                            <div class="menu-text">
                                                <h3><span>@product.Name</span> <strong>$@product.UnitPrice.ToString("0.00")</strong></h3>
                                                <p>@(string.IsNullOrWhiteSpace(product.Description) ? "Delicious freshly prepared meal" : product.Description)</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="col-lg-5 d-none d-lg-block">
                                    <img src="@GetCategoryImageUrl(category.Name)" alt="@category.Name">
                                </div>
                            </div>
                        </div>
                        isFirst = false;
                    }
                }
            </div>
        </div>
    </div>
</div>
<!-- Menu End -->

@code {
    private List<CategoryResponse>? _categories;
    private List<ProductResponse>? _products;

    protected override async Task OnInitializedAsync()
    {
        var categoryResult = await CategoryService.GetAllCategoriesAsync();
        if (categoryResult != null && categoryResult.IsSucceed && categoryResult.Data != null)
        {
            _categories = categoryResult.Data.ToList();
        }

        var productResult = await ProductService.GetAllProductsAsync();
        if (productResult != null && productResult.IsSucceed && productResult.Data != null)
        {
            _products = productResult.Data.ToList();
        }
    }

    private string GetProductImageUrl(ProductResponse product)
    {
        if (product.PrimaryImage != null && !string.IsNullOrWhiteSpace(product.PrimaryImage.Url))
        {
            return product.PrimaryImage.Url;
        }
        
        // Dummy placeholder if no image exists
        return "img/menu-burger.jpg";
    }

    private string GetCategoryImageUrl(string categoryName)
    {
        // For right-side big image based on category
        var lowerName = categoryName.ToLower();
        if (lowerName.Contains("burger")) return "img/menu-burger-img.jpg";
        if (lowerName.Contains("snack")) return "img/menu-snack-img.jpg";
        if (lowerName.Contains("beverage") || lowerName.Contains("drink")) return "img/menu-beverage-img.jpg";
        
        return "img/menu-burger-img.jpg";
    }

    private string GetCategoryIcon(string categoryName)
    {
        var lowerName = categoryName.ToLower();
        if (lowerName.Contains("burger")) return "flaticon-burger";
        if (lowerName.Contains("snack")) return "flaticon-snack";
        if (lowerName.Contains("beverage") || lowerName.Contains("drink")) return "flaticon-cocktail";
        if (lowerName.Contains("pizza")) return "flaticon-pizza";
        
        return "flaticon-burger";
    }
}
